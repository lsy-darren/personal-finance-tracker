# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Sensitive personal data to redact from bank statements
# Add comma-separated values: full name, NRIC, account numbers, address fragments, etc.
# Example: SENSITIVE_DATA=John Doe,S1234567A,123 Example Road,Account1234
SENSITIVE_DATA=Your Full Name,NRIC,Partial Account Numbers,Address Keywords
